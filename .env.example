# URL панели Remnawave
REMNAWAVE_API_URL=https://your-panel.example.com
# API токен для доступа к Remnawave API
REMNAWAVE_API_TOKEN=your-api-token-here

# Токен Telegram бота для уведомлений и управления
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# ID чата для уведомлений (может быть отрицательным для групп)
TELEGRAM_CHAT_ID=-1001234567890
# ID темы (thread) в чате, 0 = без темы (по умолчанию: 0)
TELEGRAM_THREAD_ID=0
# ID администраторов Telegram через запятую — те, кто может управлять ботом (обязательное)
TELEGRAM_ADMIN_IDS=111111111,222222222

# Язык интерфейса: "ru" или "en" (по умолчанию: ru)
# Interface language: "ru" or "en" (default: ru)
LANGUAGE=ru

# Интервал проверки подключений в секундах (по умолчанию: 60)
CHECK_INTERVAL=120
# Окно активности IP в секундах — IP считается активным, если был замечен в течение этого времени (по умолчанию: 180)
ACTIVE_IP_WINDOW=180
# Допуск — количество дополнительных IP сверх лимита перед срабатыванием (по умолчанию: 1)
TOLERANCE=1
# Кулдаун в секундах — минимальный интервал между повторными действиями для одного пользователя (по умолчанию: 600)
COOLDOWN=600
# Время жизни кэша данных пользователя в секундах (по умолчанию: 600)
USER_CACHE_TTL=600
# Глобальный лимит устройств по умолчанию, если у пользователя не задан свой (по умолчанию: 0 — без ограничений)
DEFAULT_DEVICE_LIMIT=0

# Режим действия: "manual" — только уведомление бота с возможностью принятия решения по ограничению, "auto" — автоматическое отключение подписки (по умолчанию: manual)
ACTION_MODE=manual
# Длительность автоматического отключения в минутах, 0 = навсегда (по умолчанию: 10)
AUTO_DISABLE_DURATION=10

# UUID подписок через запятую, которые не подлежат проверке
WHITELIST_USER_IDS=

# URL подключения к Redis (по умолчанию: redis://redis:6379)
REDIS_URL=redis://redis:6379

# Часовой пояс для отображения времени (по умолчанию: UTC)
TIMEZONE=UTC
